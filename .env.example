DATABASE_URL=postgresql://postgres:password@localhost:5432/cms_db
JWT_SECRET=change-this-secret-in-production
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000
PORT=3001
NODE_ENV=development
ADMIN_EMAIL=admin@citymega.org
ADMIN_PASSWORD=Admin@123456

# ── Uwazii SMS ────────────────────────────────────────────────────────────────
# Generate once from: POST https://restapi.uwaziimobile.com/v1/auth/token
# Valid for up to 10 years — store it securely, never commit to git
UWAZII_ACCESS_TOKEN=your-uwazii-access-token-here

# Sender name shown on the recipient's handset (max ~11 chars, no spaces)
UWAZII_FROM=CityMega

# Public URL Uwazii will POST delivery reports (DLR) to
# Must be reachable from the internet — use ngrok for local dev
UWAZII_CALLBACK_URL=https://yourdomain.com/messaging/dlr

# Uwazii API base URL (do not change unless Uwazii updates it)
UWAZII_BASE_URL=https://restapi.uwaziimobile.com
