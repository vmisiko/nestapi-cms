  "info": {
    "title": "City Mega Church CMS API",
    "description": "REST API for the City Mega Church management system",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "UserResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": [
              "super_admin",
              "admin",
              "staff"
            ]
          },
          "isActive": {
            "type": "boolean"
          },
          "lastLoginAt": {
            "type": "object",
            "nullable": true
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "email",
          "role",
          "isActive",
          "lastLoginAt",
          "createdAt",
          "updatedAt"
        ]
      },
      "CreateUserDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "staff@citymega.org"
          },
          "password": {
            "type": "string",
            "example": "StaffPass@1",
            "minLength": 8
          },
          "role": {
            "type": "string",
            "enum": [
              "super_admin",
              "admin",
              "staff"
            ],
            "example": "staff"
          }
        },
        "required": [
          "email",
          "password",
          "role"
        ]
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "super_admin",
              "admin",
              "staff"
            ]
          },
          "isActive": {
            "type": "boolean"
          },
          "password": {
            "type": "string",
            "minLength": 8
          }
        }
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "admin@citymega.org"
          },
          "password": {
            "type": "string",
            "example": "Admin@123456",
            "minLength": 8
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
